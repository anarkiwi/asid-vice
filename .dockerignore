# .dockerignore — keep the docker build context to source-only.
#
# The Dockerfile runs `./autogen.sh` and `./configure` inside the builder
# stage, so every autotools- or compiler-generated artifact in the working
# tree must be excluded; otherwise a stale `Makefile`, `config.status`, or
# `*.o` from a host `make` would shadow the in-container regeneration and
# the resulting image would not reflect the current source.

# --- VCS metadata --------------------------------------------------------
.git/
.gitignore
.gitattributes
.github/
renovate.json

# --- autotools artifacts (regenerated by autogen.sh / configure) ---------
# `*.in` templates (e.g. config.h.in, debug.h.in, version.h.in,
# vice-version.sh.in) are checked into VCS and must STAY in the context;
# only Makefile.in and the configure-generated outputs are excluded.
autom4te.cache/
**/autom4te.cache/
**/.aclocal.out
**/.autoconf.out
**/.autoheader.out
**/.automake.out
**/.libtoolize.out
**/config.status
**/config.log
**/config.cache
**/configure
**/configure~
**/Makefile
**/Makefile.in
**/aclocal.m4
**/depcomp
**/install-sh
**/missing
**/compile
**/config.guess
**/config.sub
**/config.rpath
**/mkinstalldirs
**/ltmain.sh
**/ylwrap
**/test-driver
src/config.h
src/stamp-h1

# --- compiled output -----------------------------------------------------
**/*.o
**/*.a
**/*.lo
**/*.la
**/*.so
**/*.so.*
**/*.dylib
**/*.dll
**/*.exe
**/.deps/
**/.libs/
**/*.gcda
**/*.gcno

# --- emulator binaries (built into src/) ---------------------------------
src/x64
src/x64sc
src/x64dtv
src/x128
src/xvic
src/xpet
src/xplus4
src/xcbm2
src/xcbm5x0
src/xscpu64
src/vsid

# --- generated lexer/parser sources --------------------------------------
# Listed in BUILT_SOURCES; regenerated by flex/byacc inside the container.
src/monitor/mon_lex.c
src/monitor/mon_parse.c
src/monitor/mon_parse.h

# --- documentation build outputs -----------------------------------------
doc/html/*.html
doc/html/*.png
doc/html/COPYING
doc/html/NEWS
doc/*.info
doc/*.info-*
doc/*.pdf
doc/*.aux
doc/*.cp
doc/*.cps
doc/*.fn
doc/*.ky
doc/*.log
doc/*.pg
doc/*.toc
doc/*.tp
doc/*.vr

# --- runtime / editor noise ----------------------------------------------
*.swp
*.swo
*~
.DS_Store
*.tmp
*.tmp.*
**/vice.log
**/snapshot.vsf

# --- build/CI scratch ----------------------------------------------------
# Note: `build/` at the repo root is *source* (per-platform Makefile.am
# fragments for beos / macOS / mingw), not a build-output dir, so don't
# exclude it.
dist/
.cache/
.vscode/
.idea/
*.dockerignore.bak

# --- existing alternate Dockerfile ---------------------------------------
# The fork already ships Dockerfile.2410 (a thin wrapper around build.sh).
# It's source, not output, so it stays in the context, but listing it here
# makes the dependency explicit if someone removes it later.
# Dockerfile.2410
